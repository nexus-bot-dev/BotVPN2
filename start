#!/bin/bash
# Colors
green="\e[38;5;82m"
red="\e[38;5;196m"
neutral="\e[0m"
orange="\e[38;5;130m"
blue="\e[38;5;39m"
yellow="\e[38;5;226m"
reset="\e[0m"

hapus_bot_lama() {
    echo -e "${orange}Menghapus bot lama...${neutral}"
    systemctl stop sellvpn.service 2>/dev/null
    systemctl disable sellvpn.service 2>/dev/null
    rm -f /etc/systemd/system/sellvpn.service
    rm -f /usr/bin/sellvpn /usr/bin/server_sellvpn /etc/cron.d/server_sellvpn
    rm -rf /root/BotVPN2

    if command -v pm2 &> /dev/null; then
        pm2 delete sellvpn &> /dev/null
        pm2 save &> /dev/null
    fi

    systemctl daemon-reload
    echo -e "${green}Bot lama berhasil dihapus.${neutral}"
}

pasang_package() {
    echo -e "${blue}Memulai pengecekan dan instalasi dependensi...${reset}"

    # Install Node.js v20
    if ! command -v node >/dev/null 2>&1 || ! node -v | grep -q 'v20'; then
        curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
        apt-get install -y nodejs
    fi

    # Downgrade npm ke versi 10 agar kompatibel
    npm install -g npm@10

    # Install PM2 secara global
    npm install -g pm2

    # Install dependencies APT
    apt update
    apt install -y build-essential git curl cron
}

setup_bot() {
    timedatectl set-timezone Asia/Jakarta

    # Clone Bot
    if [ ! -d /root/BotVPN2 ]; then
        git clone https://github.com/nexus-bot-dev/BotVPN2.git /root/BotVPN2
    fi

    # Install dependencies
    cd /root/BotVPN2
    npm install sqlite3 express crypto telegraf axios dotenv node-fetch form-data
    rm -rf node_modules
    npm install
    npm uninstall node-fetch
    npm install node-fetch@2
    chmod +x /root/BotVPN2/*
}

server_app() {
    clear
    echo -e "${orange}─────────────────────────────────────────${neutral}"
    echo -e "${green}   BOT SELLVPN TELEGRAM BY NEXUSDEV       ${neutral}"
    echo -e "${orange}─────────────────────────────────────────${neutral}"

    read -p "Masukkan token bot: " token
    while [ -z "$token" ]; do read -p "Masukkan token bot: " token; done

    read -p "Masukkan admin ID: " adminid
    while [ -z "$adminid" ]; do read -p "Masukkan admin ID: " adminid; done

    read -p "Masukkan nama store: " namastore
    while [ -z "$namastore" ]; do read -p "Masukkan nama store: " namastore; done

    read -p "Masukkan Payment API Key (dari payment.vpnnexus.biz.id): " payment_apikey
    while [ -z "$payment_apikey" ]; do read -p "Masukkan Payment API Key: " payment_apikey; done

    read -p "Masukkan Chat ID Group Telegram: " chatid_group
    while [ -z "$chatid_group" ]; do read -p "Masukkan Chat ID Group Telegram: " chatid_group; done

    read -p "Masukkan Username Grup ( contoh: mynexustunnel ): " username_grup
    while [ -z "$username_grup" ]; do read -p "Masukkan USERNAME GRUP: " username_grup; done

    read -p "Masukkan Nomor WA ( 62xxxxx ): " nomor_wa
    while [ -z "$nomor_wa" ]; do read -p "Masukkan NOMOR WA: " nomor_wa; done

    # Simpan konfigurasi ke file .vars.json
    cat >/root/BotVPN2/.vars.json <<EOF
{
  "BOT_TOKEN": "$token",
  "USER_ID": "$adminid",
  "NAMA_STORE": "$namastore",
  "PORT": "50123",
  "PAYMENT_APIKEY": "$payment_apikey",
  "GROUP_CHAT_ID": "$chatid_group",
  "ADMIN_WA": "$nomor_wa",
  "GROUP_USERNAME": "$username_grup"
}
EOF

    # Deteksi lokasi node
    NODE_PATH=$(which node)
    if [ -z "$NODE_PATH" ]; then
        echo -e "${red}Node.js tidak ditemukan. Pastikan Node.js sudah terinstall.${neutral}"
        exit 1
    fi
    echo -e "${green}Node.js ditemukan di: $NODE_PATH${neutral}"

    # Buat ecosystem.config.js untuk PM2
    cat >/root/BotVPN2/ecosystem.config.js <<EOF
module.exports = {
  apps: [
    {
      name: 'sellvpn',
      script: 'app.js',
      cwd: '/root/BotVPN2',
      interpreter: '$NODE_PATH',
      restart_delay: 3000,
      max_restarts: 10,
      autorestart: true,
      watch: false,
      env: {
        NODE_ENV: 'production',
        TZ: 'Asia/Jakarta'
      },
      output: '/var/log/sellvpn.log',
      error: '/var/log/sellvpn-error.log',
      log_date_format: 'YYYY-MM-DD HH:mm:ss'
    }
  ]
};
EOF

    # Jalankan bot dengan PM2
    cd /root/BotVPN2
    pm2 start ecosystem.config.js

    # Simpan config PM2 agar auto start setelah reboot
    pm2 save

    # Set PM2 startup agar jalan otomatis saat VPS reboot
    pm2 startup systemd -u root --hp /root | tail -1 | bash

    service cron restart

    echo -e ""
    echo -e "${orange}─────────────────────────────────────────${neutral}"
    pm2 status sellvpn
    echo -e "${orange}─────────────────────────────────────────${neutral}"
    echo -e "${green}Bot berhasil diinstal dan berjalan dengan PM2.${neutral}"
    echo -e "${yellow}Perintah PM2 berguna:${neutral}"
    echo -e "  pm2 status           - Cek status bot"
    echo -e "  pm2 logs sellvpn     - Lihat log bot"
    echo -e "  pm2 restart sellvpn  - Restart bot"
    echo -e "  pm2 stop sellvpn     - Stop bot"
    echo -e "${orange}─────────────────────────────────────────${neutral}"
}

if [[ $1 == "sellvpn" ]]; then
    hapus_bot_lama
    pasang_package
    setup_bot
    server_app
else
    echo -e "${red}Perintah tidak valid. Gunakan: ${yellow}start sellvpn${neutral}"
    exit 1
fi
